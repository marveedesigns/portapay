PORTAPAY_CORE_PORT=4000
PORTAPAY_ADMIN_PORT=5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174
CORS_ALLOW_ALL=false
NODE_ENV=development
DATABASE_URL=postgres://portapay:portapay@localhost:5432/portapay
REDIS_HOST=localhost
REDIS_PORT=6379
JWT_ACCESS_SECRET=replace-with-a-long-random-secret
JWT_REFRESH_SECRET=replace-with-another-long-random-secret
WEBHOOK_SECRET_ENCRYPTION_KEY=replace-with-32-byte-minimum-secret
ADMIN_EMAIL=admin@portapay.local
ADMIN_PASSWORD=replace-with-admin-password
PORTAPAY_DEV_API_KEY=replace-with-local-dev-api-key
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
NOMBA_ENV=test
NOMBA_MOCK=false
NOMBA_WEBHOOK_URL=https://your-deployed-api.example.com/api/v1/webhooks/nomba
NOMBA_TEST_BASE_URL=https://sandbox.nomba.com
NOMBA_TEST_CLIENT_ID=
NOMBA_TEST_CLIENT_SECRET=
NOMBA_TEST_PARENT_ACCOUNT_ID=
NOMBA_TEST_SUB_ACCOUNT_ID=
NOMBA_TEST_WEBHOOK_SECRET=
NOMBA_LIVE_BASE_URL=https://api.nomba.com
NOMBA_LIVE_CLIENT_ID=
NOMBA_LIVE_CLIENT_SECRET=
NOMBA_LIVE_PARENT_ACCOUNT_ID=
NOMBA_LIVE_SUB_ACCOUNT_ID=
NOMBA_LIVE_WEBHOOK_SECRET=
